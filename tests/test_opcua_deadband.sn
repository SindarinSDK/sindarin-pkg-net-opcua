# ==============================================================================
# test_opcua_deadband.sn - Deadband filtering on data change subscriptions
# ==============================================================================

import "../src/opcua"
import "./opcua_test_server"
import "sindarin-pkg-sdk/src/time/time"

fn test_absolute_deadband(): void =>
  print("test_absolute_deadband: ")
  var server: OpcUaTestServer = OpcUaTestServer.start(14892, 0)
  var client: OpcUaClient = OpcUaClient.connect(server.url())

  var sub: OpcUaSubscription = client.createSubscription(100.0)

  # Monitor Demo.Analog with absolute deadband of 5.0
  # deadbandType: 1 = Absolute
  var item: OpcUaMonitoredItem = sub.monitorDataChangeFiltered(
    OpcUaNodeId.stringId(2, "Demo.Analog"), 100.0, 10, 1, 5.0)
  assert(item.id() > 0, "monitored item should have an id")

  # Set initial value and drain the initial notification
  server.setAnalog(25.0)
  var initial: OpcUaDataChangeEvent = sub.nextEvent(2000)
  assert(!initial.isEmpty(), "expected initial notification")

  # Write values within deadband (delta < 5.0) — should NOT trigger
  server.setAnalog(26.0)
  Time.sleep(300)
  server.setAnalog(27.0)
  Time.sleep(300)
  server.setAnalog(28.0)
  Time.sleep(300)

  var noEvent: OpcUaDataChangeEvent = sub.nextEvent(500)
  assert(noEvent.isEmpty(), "within-deadband changes should NOT trigger notification")

  # Write value exceeding deadband (|35 - 25| = 10 > 5) — SHOULD trigger
  server.setAnalog(35.0)
  var bigChange: OpcUaDataChangeEvent = sub.nextEvent(2000)
  assert(!bigChange.isEmpty(), "exceeding-deadband change should trigger notification")
  assert(bigChange.value().asDouble() == 35.0, $"expected value 35.0, got {bigChange.value().asDouble()}")

  sub.delete()
  client.disconnect()
  server.stop()
  print("PASS\n")

fn main(): void =>
  test_absolute_deadband()
