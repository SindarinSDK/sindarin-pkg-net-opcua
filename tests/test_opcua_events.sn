# ==============================================================================
# test_opcua_events.sn - Event subscriptions
# ==============================================================================

import "../src/opcua"
import "./opcua_test_server"
import "sindarin-pkg-sdk/src/time/time"

fn test_event_subscription(): void =>
  print("test_event_subscription: ")
  var server: OpcUaTestServer = OpcUaTestServer.start(14893, 0)
  var client: OpcUaClient = OpcUaClient.connect(server.url())

  var sub: OpcUaSubscription = client.createSubscription(100.0)

  # Build event filter selecting: EventType, SourceName, Severity, Message
  var clauses: OpcUaSelectClause[] = {
    OpcUaSelectClause.field("EventType"),
    OpcUaSelectClause.field("SourceName"),
    OpcUaSelectClause.field("Severity"),
    OpcUaSelectClause.field("Message")
  }
  var filter: OpcUaEventFilter = OpcUaEventFilter.select(clauses)

  # Monitor events on the Demo folder
  var item: OpcUaMonitoredItem = sub.monitorEvents(OpcUaNodeId.stringId(2, "Demo"), filter)
  assert(item.id() > 0, "event monitored item should have an id")

  # Allow subscription to settle
  Time.sleep(500)

  # Trigger an event from the test server
  server.triggerEvent(500, "Test alarm triggered")

  # Wait for the event notification
  var notif: OpcUaEventNotification = sub.nextEventNotification(3000)
  assert(!notif.isEmpty(), "expected an event notification")
  assert(notif.fieldCount() == 4, $"expected 4 fields, got {notif.fieldCount()}")

  # Field 2 = Severity (UInt16, delivered as variant)
  var sevVar: OpcUaVariant = notif.field(2)
  assert(!sevVar.isNull(), "severity field should not be null")

  sub.delete()
  client.disconnect()
  server.stop()
  print("PASS\n")

fn test_nested_field_select(): void =>
  print("test_nested_field_select: ")
  var server: OpcUaTestServer = OpcUaTestServer.start(14894, 0)
  var client: OpcUaClient = OpcUaClient.connect(server.url())

  var sub: OpcUaSubscription = client.createSubscription(100.0)

  # Build filter with all standard BaseEventType fields
  var clauses: OpcUaSelectClause[] = {
    OpcUaSelectClause.field("EventId"),
    OpcUaSelectClause.field("EventType"),
    OpcUaSelectClause.field("SourceName"),
    OpcUaSelectClause.field("Time"),
    OpcUaSelectClause.field("Message"),
    OpcUaSelectClause.field("Severity")
  }
  var filter: OpcUaEventFilter = OpcUaEventFilter.select(clauses)
  var item: OpcUaMonitoredItem = sub.monitorEvents(OpcUaNodeId.stringId(2, "Demo"), filter)
  assert(item.id() > 0, "event monitored item should have an id")

  Time.sleep(500)

  server.triggerEvent(800, "High temperature alarm")

  var notif: OpcUaEventNotification = sub.nextEventNotification(5000)
  assert(!notif.isEmpty(), "expected event notification")
  assert(notif.fieldCount() == 6, $"expected 6 fields, got {notif.fieldCount()}")

  # Verify severity (index 5) is accessible
  var sevVar: OpcUaVariant = notif.field(5)
  assert(!sevVar.isNull(), "severity field should not be null")

  sub.delete()
  client.disconnect()
  server.stop()
  print("PASS\n")

fn main(): void =>
  test_event_subscription()
  test_nested_field_select()
